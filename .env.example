# ─── Encuestum · variables de entorno ───────────────────────────────────────
# Copiá este archivo a `.env` y ajustá los valores. Con lo mínimo (un
# SESSION_SECRET) el backend arranca con SQLite, crea el esquema por migraciones
# y ya podés registrarte. La corrección con IA sólo necesita una API key.

# ── Backend: sesiones (IMPORTANTE en producción) ─────────────────────────────
# Firma las cookies de sesión. DEBE ser estable y secreto: si cambia, se
# invalidan todas las sesiones. Generá uno con: openssl rand -hex 32
ENCUESTUM_SESSION_SECRET=
# Cookies seguras (solo HTTPS). Dejalo en true en producción; poné false para
# probar en http://localhost sin HTTPS.
# ENCUESTUM_COOKIE_SECURE=true
# ENCUESTUM_SESSION_TTL_DAYS=30
# Permitir auto-registro público. Poné false para bloquear el alta de cuentas.
# ENCUESTUM_ALLOW_REGISTRATION=true
# Super-admin de la plataforma: este email siempre tiene acceso al panel /admin
# (todas las organizaciones, usuarios y uso).
# ENCUESTUM_SUPERADMIN_EMAIL=vos@tudominio.com

# ── Backend: base de datos ──────────────────────────────────────────────────
# Por defecto SQLite en ENCUESTUM_DATA_DIR. Para Postgres, descomentá:
# DATABASE_URL=postgresql://user:pass@host:5432/encuestum
# ENCUESTUM_DATA_DIR=/app_data
# Las migraciones corren solas al arrancar; para controlarlas aparte:
# ENCUESTUM_AUTO_MIGRATE=false

# ── Backend: proveedor LLM (OpenAI-compatible: OpenRouter / OpenAI / local) ──
# Bring-your-own-key. Sin key, la corrección determinística sigue andando; la
# corrección por rúbrica con LLM y la generación de preguntas quedan inactivas.
ENCUESTUM_LLM_API_KEY=
# Base URL del proveedor (default: https://openrouter.ai/api/v1)
# ENCUESTUM_LLM_BASE_URL=https://openrouter.ai/api/v1
# Modelo (default: openai/gpt-4o-mini)
# ENCUESTUM_LLM_MODEL=openai/gpt-4o-mini

# ── Backend: seguridad ──────────────────────────────────────────────────────
# Orígenes permitidos para CORS (separados por coma). Vacío = same-origin (la
# imagen all-in-one). En dev con frontend y backend en puertos distintos:
# ENCUESTUM_CORS_ORIGINS=http://localhost:3000
# ENCUESTUM_ENABLE_HSTS=true
# ENCUESTUM_RATE_LIMIT_ENABLED=true
# ENCUESTUM_LOG_FORMAT=json   # o "text" para dev
# Rate limiting compartido entre instancias (opcional): Redis.
# ENCUESTUM_REDIS_URL=redis://localhost:6379/0

# ── Backend: email (invitaciones, reset de contraseña, verificación) ─────────
# URL pública donde vive el FRONTEND (los enlaces de los emails apuntan ahí).
# En la imagen all-in-one es el dominio del contenedor; en dev, el del frontend.
# ENCUESTUM_PUBLIC_URL=http://localhost:3000
# SMTP: si no lo configurás, los emails se LOGUEAN (el enlace queda en el log),
# así los flujos son usables sin servidor de correo.
# ENCUESTUM_SMTP_HOST=smtp.tuservidor.com
# ENCUESTUM_SMTP_PORT=587
# ENCUESTUM_SMTP_USER=
# ENCUESTUM_SMTP_PASSWORD=
# ENCUESTUM_SMTP_TLS=true
# ENCUESTUM_EMAIL_FROM=Encuestum <no-reply@tudominio.com>
# Exigir email verificado antes de ingresar (default false para no bloquear
# cuentas cuando no hay SMTP):
# ENCUESTUM_REQUIRE_EMAIL_VERIFICATION=false

# ── Backend: assets de diseño (imágenes/audio subidos) ──────────────────────
# Se guardan bajo ENCUESTUM_DATA_DIR/assets por defecto y se sirven en /assets.
# ENCUESTUM_ASSET_DIR=/app_data/assets
# ENCUESTUM_ASSET_MAX_IMAGE_MB=8
# ENCUESTUM_ASSET_MAX_AUDIO_MB=15
# ENCUESTUM_ASSET_MAX_VIDEO_MB=50

# ── Backend: storage de archivos (local o Cloudflare R2 / S3) ────────────────
# "local" = disco (ENCUESTUM_ASSET_DIR). "s3" = bucket S3-compatible: los
# archivos grandes (videos de respuesta) suben DIRECTO del navegador al bucket
# con URL firmada, así el server no los toca. Recomendado: Cloudflare R2.
# ENCUESTUM_STORAGE=s3
# ENCUESTUM_S3_ENDPOINT=https://<ACCOUNT_ID>.r2.cloudflarestorage.com
# ENCUESTUM_S3_BUCKET=encuestum
# ENCUESTUM_S3_ACCESS_KEY_ID=<r2-access-key>
# ENCUESTUM_S3_SECRET_ACCESS_KEY=<r2-secret>
# ENCUESTUM_S3_REGION=auto
# URL pública para SERVIR los archivos (dominio público del bucket R2 o tu CDN):
# ENCUESTUM_S3_PUBLIC_URL=https://cdn.tudominio.com
# (opcional) prefijo de carpeta dentro del bucket:
# ENCUESTUM_S3_PREFIX=
# El bucket necesita: acceso público de lectura (dominio r2.dev o custom) y una
# regla CORS que permita PUT/GET desde el dominio de tu app.
# Nota: las tipografías del panel de diseño se cargan desde Google Fonts, así que
# el navegador del respondiente necesita salida a internet para verlas (si no,
# cae a la fuente del sistema). Las imágenes/audio se sirven desde tu instancia.

# ── Frontend ────────────────────────────────────────────────────────────────
# URL del backend, embebida en el bundle al buildear (build arg en Docker).
# En la imagen all-in-one dejalo VACÍO (same-origin, nginx enruta /api).
# En dev con docker-compose (dos servicios): http://localhost:8000
NEXT_PUBLIC_API_URL=http://localhost:8000
