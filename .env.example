# ─── Encuestum · variables de entorno ───────────────────────────────────────
# Copiá este archivo a `.env` y ajustá los valores. Todo es opcional: sin nada
# configurado, el backend arranca con SQLite y las encuestas funcionan; la
# corrección con IA sólo necesita una API key.

# ── Backend: base de datos ──────────────────────────────────────────────────
# Por defecto SQLite en ENCUESTUM_DATA_DIR. Para Postgres, descomentá:
# DATABASE_URL=postgresql://user:pass@host:5432/encuestum
# ENCUESTUM_DATA_DIR=/data

# ── Backend: proveedor LLM (OpenAI-compatible: OpenRouter / OpenAI / local) ──
# Bring-your-own-key. Sin key, la corrección determinística sigue andando; la
# corrección por rúbrica con LLM y la generación de preguntas quedan inactivas.
ENCUESTUM_LLM_API_KEY=
# Base URL del proveedor (default: https://openrouter.ai/api/v1)
# ENCUESTUM_LLM_BASE_URL=https://openrouter.ai/api/v1
# Modelo (default: openai/gpt-4o-mini)
# ENCUESTUM_LLM_MODEL=openai/gpt-4o-mini

# ── Backend: gate admin opcional ────────────────────────────────────────────
# Si lo definís, las rutas /api/v1/survey/surveys/* exigen el header
# X-Admin-Token con este valor. Las rutas públicas siempre quedan abiertas.
# ENCUESTUM_ADMIN_TOKEN=

# ── Frontend ────────────────────────────────────────────────────────────────
# URL del backend, embebida en el bundle al buildear (build arg en Docker).
NEXT_PUBLIC_API_URL=http://localhost:8000
# Si activaste el gate admin arriba, replicá el token acá para que el panel
# pueda llamar a las rutas protegidas.
# NEXT_PUBLIC_ENCUESTUM_ADMIN_TOKEN=
